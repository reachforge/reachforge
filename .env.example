# aphype Environment Variables
# Copy this file to .env and fill in your values.

# === LLM Configuration ===
GEMINI_API_KEY=            # Required for draft/adapt commands
APHYPE_LLM_MODEL=gemini-pro  # Optional: LLM model name (default: gemini-pro)

# === Platform Provider API Keys ===
DEVTO_API_KEY=             # Dev.to Forem API key (Settings > Extensions > DEV Community API Keys)
POSTIZ_API_KEY=            # Postiz Cloud API key (for X/Twitter publishing)
HASHNODE_API_KEY=          # Hashnode Personal Access Token
HASHNODE_PUBLICATION_ID=   # Hashnode Publication ID
GITHUB_TOKEN=              # GitHub Personal Access Token (for Discussions publishing)
GITHUB_OWNER=              # GitHub repository owner
GITHUB_REPO=               # GitHub repository name
GITHUB_DISCUSSION_CATEGORY=General  # GitHub Discussions category

# === MCP Server ===
MCP_AUTH_KEY=              # Optional: API key for MCP server authentication
