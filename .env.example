# ReachForge Environment Variables
# `reach init` copies this file as .env into your workspace.
# All settings are commented out by default — uncomment and fill in only what you need.

# === LLM Adapter Configuration ===
# ReachForge uses local CLI tools (claude, gemini, codex) — no API keys needed.
# Make sure the CLI is installed and authenticated before use.
#
# Supported adapters: claude, gemini, codex
# REACHFORGE_LLM_ADAPTER=claude

# Per-stage overrides (optional):
# REACHFORGE_DRAFT_ADAPTER=gemini
# REACHFORGE_ADAPT_ADAPTER=claude

# Custom CLI paths (optional, only if not in PATH):
# REACHFORGE_CLAUDE_COMMAND=/usr/local/bin/claude
# REACHFORGE_GEMINI_COMMAND=/usr/local/bin/gemini
# REACHFORGE_CODEX_COMMAND=/usr/local/bin/codex

# === Platform Provider API Keys ===
# Only needed for the platforms you publish to.
# Without a key the platform silently falls back to mock mode (dry-run).
# DEVTO_API_KEY=             # Dev.to: Settings > Extensions > DEV Community API Keys
# POSTIZ_API_KEY=            # Postiz: Register at postiz.com, get key from Dashboard > API
# HASHNODE_API_KEY=          # Hashnode: Settings > Developer > Personal Access Tokens
# HASHNODE_PUBLICATION_ID=   # Hashnode: Dashboard > Publication > Settings > Publication ID
# GITHUB_TOKEN=              # GitHub: Settings > Developer settings > Personal access tokens
# GITHUB_OWNER=              # GitHub repository owner (e.g., "myuser")
# GITHUB_REPO=               # GitHub repository name (e.g., "my-blog")
# GITHUB_DISCUSSION_CATEGORY=General  # GitHub Discussions category name

# === Gemini API Mode (optional) ===
# Only needed if you use the Gemini SDK instead of the CLI adapter.
# GEMINI_API_KEY=

# === MCP Server (optional) ===
# Set to protect MCP endpoint with an API key.
# MCP_AUTH_KEY=
