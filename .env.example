# aphype Environment Variables
# Copy this file to .env and fill in your values.

# === LLM Adapter Configuration ===
# aphype uses local CLI tools (claude, gemini, codex) — no API keys needed.
# Make sure the CLI is installed and authenticated before use.
#
# Supported adapters: claude, gemini, codex
APHYPE_LLM_ADAPTER=claude  # Default adapter for all stages (draft, adapt, refine)

# Per-stage overrides (optional):
# APHYPE_DRAFT_ADAPTER=gemini   # Use gemini for draft generation
# APHYPE_ADAPT_ADAPTER=claude   # Use claude for platform adaptation

# Custom CLI paths (optional, only if not in PATH):
# APHYPE_CLAUDE_COMMAND=/usr/local/bin/claude
# APHYPE_GEMINI_COMMAND=/usr/local/bin/gemini

# === Platform Provider API Keys ===
DEVTO_API_KEY=             # Dev.to: Settings > Extensions > DEV Community API Keys
POSTIZ_API_KEY=            # Postiz: Register at postiz.com, get key from Dashboard > API
HASHNODE_API_KEY=          # Hashnode: Settings > Developer > Personal Access Tokens
HASHNODE_PUBLICATION_ID=   # Hashnode: Dashboard > Publication > Settings > Publication ID
GITHUB_TOKEN=              # GitHub: Settings > Developer settings > Personal access tokens
GITHUB_OWNER=              # GitHub repository owner (e.g., "myuser")
GITHUB_REPO=               # GitHub repository name (e.g., "my-blog")
GITHUB_DISCUSSION_CATEGORY=General  # GitHub Discussions category name

# === MCP Server ===
MCP_AUTH_KEY=              # Optional: API key for MCP server authentication
