{
  "name": "reachforge",
  "version": "0.3.0",
  "description": "ReachForge: The Social Influence Engine for AI-Native Content.",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "mkdir -p bin && bun build ./src/index.ts --compile --outfile bin/reach && bun run src/index.ts --help --man > bin/reach.1",
    "build:macos": "bun build ./src/index.ts --compile --target bun-darwin-arm64 --outfile bin/reach-macos",
    "build:win": "bun build ./src/index.ts --compile --target bun-windows-x64 --outfile bin/reach.exe",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "apcore-cli": ">=0.4.0",
    "apcore-js": ">=0.14.1",
    "apcore-mcp": ">=0.11.0",
    "apcore-toolkit": ">=0.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.4",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "apdev-js": ">=0.2.2",
    "bun-types": "^1.1.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reachforge/reachforge.git"
  },
  "homepage": "https://github.com/reachforge",
  "bugs": {
    "url": "https://github.com/reachforge/reachforge/issues"
  },
  "apdev": {
    "base_package": "reachforge"
  }
}